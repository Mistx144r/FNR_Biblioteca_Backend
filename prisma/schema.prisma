generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum stateEnum {
  DISPONIVEL
  RESERVADO
  EMPRESTADO
  INDISPONIVEL

  @@map("state_enum")
}

// Adicionar Depois A Cidade Do Trabalhador 
model Worker {
  id_worker         BigInt   @id @default(autoincrement())
  name              String   @db.VarChar(255)
  cpf               String   @unique @db.VarChar(14)
  password          String   @db.Text
  email             String   @unique @db.VarChar(255)
  telephone         String?  @db.VarChar(9) // Nullable
  cellphone         String   @db.VarChar(15)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  fk_institution_id BigInt

  institution Institution @relation(fields: [fk_institution_id], references: [id_institution])

  Worker_Roles Worker_Roles[]

  @@map("worker")
}

model Roles {
  id_roles     BigInt         @id @default(autoincrement())
  name         String         @db.VarChar(255)
  Worker_Roles Worker_Roles[]

  @@map("roles")
}

model Worker_Roles {
  worker_roles_id BigInt @id @default(autoincrement())
  fk_role_id      BigInt
  fk_worker_id    BigInt

  role   Roles  @relation(fields: [fk_role_id], references: [id_roles])
  worker Worker @relation(fields: [fk_worker_id], references: [id_worker])

  @@unique([fk_role_id, fk_worker_id])
  @@map("worker_roles")
}

model Book {
  id_book        BigInt   @id @default(autoincrement())
  name           String   @db.VarChar(255)
  isbn           String   @unique @db.VarChar(13) // Nullable
  description    String   @db.Text
  publisher      String   @db.VarChar(255)
  language       String   @db.VarChar(5)
  fk_category_id BigInt   @db.BigInt
  edition        Int      @db.SmallInt
  pages          Int?     @db.Integer // Nullable
  bookcover      String?  @db.Text // Nullable
  published_at   DateTime @db.Date
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  category               Category                 @relation(fields: [fk_category_id], references: [id_category])
  Authors_In_Book        Authors_In_Book[]
  Sub_Categories_Of_Book Sub_Categories_Of_Book[]
  bookCopies             Book_Copy[]

  @@map("book")
}

model Author {
  id_author       BigInt            @id @default(autoincrement())
  name            String            @db.VarChar(255)
  Authors_In_Book Authors_In_Book[]

  @@map("author")
}

model Authors_In_Book {
  authors_in_book_id BigInt @id @default(autoincrement())
  fk_author_id       BigInt
  fk_book_id         BigInt

  author Author @relation(fields: [fk_author_id], references: [id_author], onDelete: Cascade)
  book   Book   @relation(fields: [fk_book_id], references: [id_book], onDelete: Cascade)

  @@unique([fk_author_id, fk_book_id])
  @@map("authors_in_book")
}

model Sector {
  id_sector         BigInt @id @default(autoincrement())
  name              String @db.VarChar(255)
  letter            String @db.VarChar(1)
  fk_category_id    BigInt
  fk_institution_id BigInt

  category    Category    @relation(fields: [fk_category_id], references: [id_category])
  institution Institution @relation(fields: [fk_institution_id], references: [id_institution])
  Bookcase    Bookcase[]

  @@unique([fk_institution_id, name])
  @@unique([fk_institution_id, letter])
  @@map("sector")
}

model Bookcase {
  id_bookcase  BigInt @id @default(autoincrement())
  name         String @db.VarChar(255)
  fk_sector_id BigInt

  sector     Sector      @relation(fields: [fk_sector_id], references: [id_sector])
  bookCopies Book_Copy[]

  @@map("bookcase")
}

model Book_Copy {
  id_book_copy      BigInt    @id @default(autoincrement())
  fk_book_id        BigInt
  fk_bookcase_id    BigInt
  fk_institution_id BigInt
  is_consult        Boolean   @default(false)
  state             stateEnum @default(DISPONIVEL)
  is_virtual        Boolean   @default(false)
  description       String?   @db.Text // Nullable

  bookcase    Bookcase    @relation(fields: [fk_bookcase_id], references: [id_bookcase])
  book        Book        @relation(fields: [fk_book_id], references: [id_book])
  institution Institution @relation(fields: [fk_institution_id], references: [id_institution])

  @@map("book_copy")
}

model Institution {
  id_institution BigInt      @id @default(autoincrement())
  name           String      @db.VarChar(255)
  bookCopies     Book_Copy[]
  sectors        Sector[]
  workers        Worker[]

  @@map("institution")
}

model Category {
  id_category BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(255)
  Book        Book[]
  Sector      Sector[]

  @@map("category")
}

model Sub_Category {
  id_sub_category        BigInt                   @id @default(autoincrement())
  name                   String                   @db.VarChar(255)
  Sub_Categories_Of_Book Sub_Categories_Of_Book[]

  @@map("sub_category")
}

model Sub_Categories_Of_Book {
  id_sub_categories_of_book BigInt @id @default(autoincrement())
  fk_sub_category           BigInt
  fk_book_id                BigInt

  sub_category Sub_Category @relation(fields: [fk_sub_category], references: [id_sub_category], onDelete: Cascade)
  book         Book         @relation(fields: [fk_book_id], references: [id_book], onDelete: Cascade)

  @@unique([fk_sub_category, fk_book_id])
  @@map("sub_categories_in_book")
}
